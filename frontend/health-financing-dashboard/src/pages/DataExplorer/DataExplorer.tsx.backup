const DataExplorer: React.FC = () => {
  const [countries, setCountries] = useState<string[]>([]);
  const [selectedCountries, setSelectedCountries] = useState<string[]>([]);
  const [indicator, setIndicator] = useState<string>('Gov exp Health per capita');
  const [data, setData] = useState<any[]>([]);
  const [loading, setLoading] = useState<boolean>(false);
  const [masterData, setMasterData] = useState<any[]>([]);
  const [dataLoaded, setDataLoaded] = useState<boolean>(false);

  // Load countries and master data once on mount
  useEffect(() => {
    const loadInitialData = async () => {
      setLoading(true);
      try {
        console.log('Loading countries...');
        const countryList = await api.getCountries();
        console.log('Countries loaded:', countryList?.length);

        console.log('Loading master data...');
        const rawData = await api.getMasterData();
        console.log('Raw data type:', typeof rawData, 'isArray:', Array.isArray(rawData));

        setCountries(Array.isArray(countryList) ? countryList : []);

        // Handle different response formats
        let parsedData: any[] = [];
        if (Array.isArray(rawData)) {
          parsedData = rawData;
        } else if (typeof rawData === 'string') {
          try {
            parsedData = JSON.parse(rawData);
          } catch (e) {
            console.error('Failed to parse rawData as JSON:', e);
          }
        } else if (rawData && typeof rawData === 'object') {
          // Maybe it's wrapped in an object
          const obj = rawData as any;
          parsedData = obj.data || obj.records || [];
        }

        console.log('Parsed data records:', parsedData.length);
        setMasterData(parsedData);
        setDataLoaded(true);

        if (Array.isArray(countryList) && countryList.length >= 2) {
          setSelectedCountries([countryList[0], countryList[1]]);
        }
      } catch (error) {
        console.error('Error loading initial data:', error);
      } finally {
        setLoading(false);
      }
    };
    loadInitialData();
  }, []);

  // Process chart data when selection changes (no API call needed)
  useEffect(() => {
    if (!dataLoaded || selectedCountries.length === 0 || !Array.isArray(masterData) || masterData.length === 0) {
      setData([]);
      return;
    }

    const filtered = masterData.filter((d: any) => selectedCountries.includes(d.location));
    const byYear = filtered.reduce((acc: any, d: any) => {
      if (!acc[d.year]) acc[d.year] = { year: d.year };
      const value = d[indicator];
      if (value !== undefined && value !== null) {
        acc[d.year][d.location] = value;
      }
      return acc;
    }, {});

    setData(Object.values(byYear).sort((a: any, b: any) => a.year - b.year));
  }, [selectedCountries, indicator, masterData, dataLoaded]);

  const handleCountryToggle = (country: string) => {
    setSelectedCountries(prev =>
      prev.includes(country)
        ? prev.filter(c => c !== country)
        : [...prev, country]
    );
  };

  const indicatorInfo = INDICATOR_INFO[indicator] || {
    title: indicator,
    description: 'No description available',
    interpretation: 'No interpretation available',
    unit: 'Value'
  };

  return (
    <div className="data-explorer-page">
      <h1>Data Explorer</h1>
      <p className="subtitle">Create custom visualizations by selecting countries and indicators</p>

      <div className="explorer-container">
        <div className="controls-panel">
          <div className="control-group">
            <h3>1. Select Indicator</h3>
            <select value={indicator} onChange={(e) => setIndicator(e.target.value)}>
              <optgroup label="3.1 Public Health Financing">
                <option value="Gov exp Health per capita">Government Health Expenditure Per Capita</option>
                <option value="Gap for Gov exp Health per capita">Health Financing Gap</option>
                <option value="Gov exp Health on GDP">Government Health Expenditure as % GDP</option>
                <option value="Gap Gov exp Health on GDP">Gap to GDP Benchmark</option>
                <option value="Gov exp Health on GDP > 5">Meets 5% GDP Benchmark</option>
                <option value="Gov exp Health on GDP > 2016 Value">Health/GDP Improved Since 2016</option>
                <option value="Gov exp Health per capita > 2016 Value">Per Capita Improved Since 2016</option>
                <option value="Gov exp Health per capita More than Threshold">Exceeds Income-Adjusted Threshold</option>
                <option value="below_threshold">Below Health Financing Threshold</option>
                <option value="meets_threshold">Meets Health Financing Threshold</option>
                <option value="public_health_gap">Public Health Gap (Alternative)</option>
                <option value="income_threshold">Income-Specific Threshold Value</option>
                <option value="gov_exp_pc_thres">Gov Expenditure Per Capita Threshold</option>
                <option value="thres50">50th Percentile Threshold</option>
                <option value="thres75">75th Percentile Threshold</option>
              </optgroup>
              <optgroup label="3.2 Budget Priority">
                <option value="Gov exp Health on budget">Government Health Budget Share (Abuja)</option>
                <option value="Gap Gov exp Health on budget">Gap to Abuja Target</option>
                <option value="Gov exp Health on budget > 15">Meets Abuja 15% Target</option>
                <option value="Gov exp Health on budget > 2016 Value">Budget Priority Improved Since 2016</option>
                <option value="below_abuja">Below Abuja Target</option>
                <option value="meets_abuja">Meets Abuja Target</option>
                <option value="budget_priority_gap">Budget Priority Gap (Alternative)</option>
              </optgroup>
              <optgroup label="3.3 Financial Protection">
                <option value="Out-of-pocket on health exp">Out-of-Pocket Expenditure Share</option>
                <option value="Out-of-pocket on health exp < 20">OOP Below 20% Benchmark</option>
                <option value="below_oop_benchmark">Below OOP Benchmark</option>
                <option value="oop_above_20">OOP Above 20% Threshold</option>
                <option value="financial_protection_gap">Financial Protection Gap</option>
                <option value="Exc Out-of-pocket on health exp">Health Expenditure Excluding OOP</option>
              </optgroup>
              <optgroup label="3.4 Financing Structure">
                <option value="Govern on health exp">Government Share of Health Exp</option>
                <option value="External on health exp">External/Donor Share of Health Exp</option>
                <option value="Domest Private on health exp">Domestic Private Health Expenditure</option>
                <option value="gov_dominant">Government is Dominant Source</option>
                <option value="dominant_financing_source">Dominant Financing Source</option>
                <option value="gov_highest">Government Has Highest Share</option>
                <option value="vol_highest">Voluntary Prepayments Highest</option>
                <option value="oop_highest">OOP is Dominant Source</option>
                <option value="other_highest">Other Private is Dominant</option>
                <option value="ext_highest">External Financing is Dominant</option>
              </optgroup>
              <optgroup label="3.5 Universal Health Coverage">
                <option value="Universal health coverage">UHC Service Coverage Index</option>
                <option value="uhc_below_50">UHC Below 50</option>
                <option value="uhc_above_50">UHC Above 50</option>
                <option value="uhc_year_avg">UHC Year-Specific Average</option>
                <option value="uhc_below_avg">UHC Below Average</option>
                <option value="uhc_below_50_or_avg">UHC Below 50 or Average</option>
                <option value="uhc_p50">UHC 50th Percentile Value</option>
                <option value="uhc_p75">UHC 75th Percentile Value</option>
                <option value="uhc_above_p50">UHC Above Median</option>
                <option value="uhc_above_p75">UHC Above 75th Percentile</option>
              </optgroup>
              <optgroup label="3.6 Health Outcomes">
                <option value="Neonatal mortality rate">Neonatal Mortality Rate</option>
                <option value="Maternal mortality ratio">Maternal Mortality Ratio</option>
              </optgroup>
              <optgroup label="3.7 Financing × UHC">
                <option value="financial hardship">Financial Hardship from Health Costs</option>
                <option value="health_tax_above_50th">Health Spending Above 50th (Tax Context)</option>
                <option value="health_tax_above_75th">Health Spending Above 75th (Tax Context)</option>
                <option value="health_gdp_above_50th">Health/GDP Above Median</option>
                <option value="health_gdp_above_75th">Health/GDP Above 75th Percentile</option>
              </optgroup>
              <optgroup label="3.8 Financing × Outcomes">
                <option value="nmr_on_course">On Track for NMR Target</option>
                <option value="mmr_on_course">On Track for MMR Target</option>
              </optgroup>
              <optgroup label="3.9 Structure × UHC">
                <option value="Voluntary Prepayments on health exp">Voluntary Health Insurance Share</option>
                <option value="Other Private on health exp">Other Private Expenditure Share</option>
              </optgroup>
              <optgroup label="3.10 Structure × Outcomes">
                <option value="imr_category">Infant Mortality Category (vs Target)</option>
                <option value="mmr_category">Maternal Mortality Category (vs Target)</option>
              </optgroup>
              <optgroup label="3.11 Fiscal Space / Economic Indicators">
                <option value="Expenditure per capita current">Total Health Expenditure Per Capita</option>
                <option value="Expenditure on GDP">Health Expenditure as % GDP</option>
                <option value="GDP per capita Current">GDP Per Capita (Current)</option>
                <option value="GDP per capita Constant 2023">GDP Per Capita (Constant 2023)</option>
                <option value="Tax Revenue per GDP">Tax Revenue as % GDP</option>
                <option value="Total Revenue per GDP">Total Government Revenue as % GDP</option>
                <option value="health_elasticity">Health Spending Elasticity</option>
                <option value="Exp Health on GDP">Total Health Exp as % GDP (Alt)</option>
                <option value="Exp Health per capita">Total Health Exp Per Capita (Alt)</option>
                <option value="Expenditure per capita constant">Health Exp Per Capita (Constant 2023)</option>
                <option value="Expenditure in million Constant 2023">Total Health Exp (Million Constant 2023)</option>
                <option value="gdp_growth">GDP Growth Rate</option>
                <option value="health_exp_growth">Health Expenditure Growth Rate</option>
                <option value="Population">Total Population</option>
                <option value="Direct foreign transfers, in million current US$">Foreign Transfers (Million Current)</option>
                <option value="Direct foreign transfers, in current US$ per capita">Foreign Transfers Per Capita (Current)</option>
                <option value="Direct foreign transfers, as % of Gross domestic product (GDP)">Foreign Transfers as % GDP</option>
                <option value="Direct foreign transfers, as % of Current Health Expenditure (CHE)">Foreign Transfers as % CHE</option>
                <option value="Direct foreign transfers, in million constant (2023) US$">Foreign Transfers (Million Constant 2023)</option>
                <option value="Direct foreign transfers, in constant (2023) US$ per capita">Foreign Transfers Per Capita (Constant 2023)</option>
                <option value="Gross fixed capital formation, in million current US$">Capital Formation (Million Current)</option>
                <option value="Gross fixed capital formation, in current US$ per capita">Capital Formation Per Capita (Current)</option>
                <option value="Gross fixed capital formation, as % of Gross domestic product (GDP)">Capital Formation as % GDP</option>
                <option value="Gross fixed capital formation, in million constant (2023) US$">Capital Formation (Million Constant 2023)</option>
                <option value="Gross fixed capital formation, in constant (2023) US$ per capita">Capital Formation Per Capita (Constant 2023)</option>
              </optgroup>
            </select>
          </div>

          <div className="control-group">
            <h3>2. Select Countries (max 5)</h3>
            <div className="country-checkboxes">
              {countries.map(country => (
                <label key={country}>
                  <input
                    type="checkbox"
                    checked={selectedCountries.includes(country)}
                    onChange={() => handleCountryToggle(country)}
                    disabled={selectedCountries.length >= 5 && !selectedCountries.includes(country)}
                  />
                  {country}
                </label>
              ))}
            </div>
            <p className="helper-text">
              {selectedCountries.length === 0 && 'Select at least one country to generate a chart'}
              {selectedCountries.length > 0 && selectedCountries.length < 5 && `${selectedCountries.length} selected. You can select up to 5 countries.`}
              {selectedCountries.length === 5 && 'Maximum 5 countries selected'}
            </p>
          </div>
        </div>

        <div className="chart-panel">
          <h3>Your Custom Chart</h3>
          <p style={{fontSize: '12px', color: '#666'}}>
            Debug: masterData={masterData.length}, selected={selectedCountries.length}, chartData={data.length}, loaded={dataLoaded ? 'yes' : 'no'}
          </p>
          {loading ? (
            <p className="no-data">Loading chart data...</p>
          ) : data.length > 0 ? (
            <ResponsiveContainer width="100%" height={500}>
              <LineChart data={data}>
                <CartesianGrid strokeDasharray="3 3" />
                <XAxis dataKey="year" />
                <YAxis />
                <Tooltip />
                <Legend />
                {selectedCountries.map((country, idx) => (
                  <Line
                    key={country}
                    type="monotone"
                    dataKey={country}
                    stroke={['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'][idx]}
                    strokeWidth={2}
                  />
                ))}
              </LineChart>
            </ResponsiveContainer>
          ) : (
            <p className="no-data">Select countries to generate a chart</p>
          )}
        </div>
      </div>

      {/* Dynamic Explanatory Notes */}
      <div className="indicator-explanation">
        <h2>About this indicator</h2>

        <div className="explanation-section">
          <h3>{indicatorInfo.title}</h3>
          <p className="indicator-description">{indicatorInfo.description}</p>
        </div>

        <div className="explanation-section">
          <h4>How to interpret this data</h4>
          <p>{indicatorInfo.interpretation}</p>
        </div>

        {indicatorInfo.benchmark && (
          <div className="explanation-section benchmark">
            <h4>📊 Benchmark</h4>
            <p className="benchmark-text">{indicatorInfo.benchmark}</p>
          </div>
        )}

        <div className="explanation-section">
          <h4>Measurement unit</h4>
          <p className="unit-text">{indicatorInfo.unit}</p>
        </div>

        {selectedCountries.length > 0 && (
          <div className="explanation-section countries-info">
            <h4>Countries you're comparing</h4>
            <div className="selected-countries-list">
              {selectedCountries.map((country, idx) => (
                <span key={country} className="country-badge" style={{
                  backgroundColor: ['#eff6ff', '#ecfdf5', '#fef3c7', '#fee2e2', '#f3e8ff'][idx],
                  color: ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'][idx]
                }}>
                  {country}
                </span>
              ))}
            </div>
          </div>
        )}

        <div className="explanation-section tip">
          <h4>💡 Pro Tip</h4>
          <p>
            Try comparing countries with different income levels or from different regions to see how
            economic development and geography impact {indicatorInfo.title.toLowerCase()}.
          </p>
        </div>
      </div>

      {/* Data Source */}
      <div className="data-source-section">
        <h3>Data Source</h3>
        <p>
          <strong>WHO Global Health Expenditure Database</strong> - All health financing indicators are
          sourced from the World Health Organization's comprehensive database covering health expenditure
          across all member states.
        </p>
        <a href="https://apps.who.int/nha/database" target="_blank" rel="noopener noreferrer">
          Visit WHO GHED →
        </a>
      </div>
    </div>
  );
};

export default DataExplorer;
