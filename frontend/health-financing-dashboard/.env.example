# =============================================
# Frontend Environment Configuration Template
# =============================================
# Copy this file to .env.local for local development
# For production, create .env.production with production values
# NEVER commit actual .env files to version control

# =============================================
# API Configuration
# =============================================

# Backend API URL
# Development: Point to local backend server
REACT_APP_API_URL=http://localhost:5000/api

# =============================================
# Analytics Configuration (Optional)
# =============================================

# Google Analytics Measurement ID
# Example: REACT_APP_GA_ID=G-XXXXXXXXXX
# REACT_APP_GA_ID=

# =============================================
# Feature Flags (Optional)
# =============================================

# Enable beta features (true/false)
# REACT_APP_ENABLE_BETA_FEATURES=false

# Enable debug mode (shows additional info in console)
# REACT_APP_DEBUG_MODE=false

# =============================================
# Environment Indicator (Optional)
# =============================================

# Display environment name in UI (development, staging, production)
# REACT_APP_ENV=development

# =============================================
# Third-Party Services (Optional)
# =============================================

# Sentry error tracking DSN
# REACT_APP_SENTRY_DSN=

# =============================================
# Notes for Development
# =============================================
#
# 1. All environment variables MUST start with REACT_APP_
#    - This is a Create React App requirement
#    - Variables without this prefix won't be accessible in the app
#
# 2. Restart the development server after changing .env files
#    - Changes to .env files are not hot-reloaded
#    - Stop the server (Ctrl+C) and run 'npm start' again
#
# 3. Environment Variables vs Build Time
#    - Environment variables are embedded at BUILD time, not runtime
#    - To change the API URL for production, set it BEFORE building
#
# =============================================
