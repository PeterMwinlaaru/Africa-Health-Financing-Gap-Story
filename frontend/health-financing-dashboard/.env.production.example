# =============================================
# Frontend Production Environment Configuration Template
# =============================================
# Copy this file to .env.production and fill in your values
# This file is used when running 'npm run build'
# NEVER commit the actual .env.production file to version control

# =============================================
# API Configuration
# =============================================

# Backend API URL for Production
#
# Option 1: Same domain deployment (recommended)
# If frontend and backend are served from the same domain
REACT_APP_API_URL=/api

# Option 2: Separate domain deployment
# If backend is hosted on a different domain
# REACT_APP_API_URL=https://api.yourdomain.com/api

# Option 3: Fly.io deployment
# If deploying to Fly.io alongside the backend
# REACT_APP_API_URL=https://your-app-name.fly.dev/api

# =============================================
# Analytics Configuration
# =============================================

# Google Analytics Measurement ID (recommended for production)
# Get this from your Google Analytics account
# Example: REACT_APP_GA_ID=G-XXXXXXXXXX
# REACT_APP_GA_ID=

# =============================================
# Environment Indicator
# =============================================

# Display environment in UI (useful for staging vs production)
REACT_APP_ENV=production

# =============================================
# Feature Flags
# =============================================

# Enable beta features in production (usually false)
REACT_APP_ENABLE_BETA_FEATURES=false

# Enable debug mode (should be false in production)
REACT_APP_DEBUG_MODE=false

# =============================================
# Error Tracking (Optional but Recommended)
# =============================================

# Sentry DSN for production error tracking
# Get this from your Sentry project settings
# REACT_APP_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# =============================================
# Performance Monitoring (Optional)
# =============================================

# Enable web vitals reporting endpoint
# REACT_APP_VITALS_ENDPOINT=https://your-analytics-endpoint.com/vitals

# =============================================
# Build Configuration (Set via command line or CI/CD)
# =============================================

# PUBLIC_URL - Base URL where the app will be hosted
# This is typically set in package.json "homepage" or via environment
# PUBLIC_URL=https://yourdomain.com

# GENERATE_SOURCEMAP - Whether to generate source maps (slower build, easier debugging)
# GENERATE_SOURCEMAP=false

# =============================================
# Important Notes for Production Deployment
# =============================================
#
# 1. API URL Configuration:
#    - If deploying frontend and backend together on the same domain,
#      use REACT_APP_API_URL=/api
#    - If deploying separately, use the full backend URL with https://
#    - Ensure CORS is properly configured on the backend
#
# 2. Build Process:
#    - Environment variables are embedded at BUILD time
#    - If you change .env.production, you must rebuild: npm run build
#    - The built files in /build directory contain the embedded values
#
# 3. Security:
#    - Never put secrets or API keys in environment variables
#    - All REACT_APP_ variables are PUBLIC (visible in browser)
#    - Use backend environment variables for sensitive data
#
# 4. Deployment Platforms:
#
#    Fly.io:
#      REACT_APP_API_URL=/api (if deploying as single app)
#      or
#      REACT_APP_API_URL=https://your-backend-app.fly.dev/api (if separate apps)
#
#    Vercel/Netlify (Frontend Only):
#      REACT_APP_API_URL=https://your-backend-domain.com/api
#
#    VPS/Nginx (Same Server):
#      REACT_APP_API_URL=/api
#      (Nginx proxies /api to backend port 5000)
#
# 5. Testing Production Build Locally:
#    npm run build
#    npx serve -s build
#    (Visit http://localhost:3000 to test)
#
# 6. Verifying Environment Variables:
#    - After build, check build/static/js/main.*.js
#    - Search for your API URL to confirm it's embedded correctly
#
# =============================================
