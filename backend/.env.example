# =============================================
# Backend Environment Configuration Template
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# =============================================
# Server Configuration
# =============================================

# Port for the API server to run on
PORT=5000

# Node environment (development, production, test)
NODE_ENV=production

# =============================================
# CORS Configuration
# =============================================

# Allowed origins for CORS (comma-separated list)
# Example for production with multiple domains:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://health-dashboard-winter-sky-9151.fly.dev
# For development:
# ALLOWED_ORIGINS=http://localhost:3000

ALLOWED_ORIGINS=http://localhost:3000

# =============================================
# Data Configuration
# =============================================

# Path to processed data directory (relative to backend root)
# Default: ../processed_data
DATA_PATH=../processed_data

# =============================================
# Logging Configuration (Optional)
# =============================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable request logging (true/false)
ENABLE_REQUEST_LOGGING=true

# =============================================
# API Configuration (Optional)
# =============================================

# API rate limiting - requests per minute (0 to disable)
# RATE_LIMIT_RPM=100

# Enable API documentation endpoint (true/false)
# ENABLE_API_DOCS=false

# =============================================
# Performance Configuration (Optional)
# =============================================

# Enable response compression (true/false)
ENABLE_COMPRESSION=true

# Cache-Control max-age for data endpoints (in seconds)
# 3600 = 1 hour, 86400 = 1 day
CACHE_MAX_AGE=3600

# =============================================
# Security Configuration (Optional)
# =============================================

# Helmet security headers (true/false)
# ENABLE_HELMET=true

# Trust proxy (set to true if behind a reverse proxy like Nginx)
# TRUST_PROXY=false

# =============================================
# Notes for Production Deployment
# =============================================
#
# 1. CORS Configuration:
#    - Update ALLOWED_ORIGINS with your actual production domain(s)
#    - Include the complementary platform URL if needed
#    - Never use '*' in production
#
# 2. Data Path:
#    - Ensure the path is correct relative to your deployment location
#    - Verify the processed_data folder is accessible
#
# 3. Security:
#    - Set NODE_ENV=production for production deployments
#    - Enable compression for better performance
#    - Consider enabling rate limiting for public APIs
#
# 4. Logging:
#    - Use 'info' or 'warn' in production
#    - Use 'debug' only for troubleshooting
#
# =============================================
